{
  "name": "@ludoows/emix",
  "version": "0.1.0",
  "description": "Event-driven state management for React — emit to mutate, Proxy to track",
  "type": "module",
  "sideEffects": false,
  "author": "ludoows",
  "license": "MIT",
  "homepage": "https://github.com/Ludows/emix#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ludows/emix.git"
  },
  "bugs": {
    "url": "https://github.com/Ludows/emix/issues"
  },
  "keywords": [
    "react",
    "state-management",
    "event-driven",
    "proxy",
    "store",
    "emit",
    "reactive"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "unpkg": "./dist/index.js",
  "jsdelivr": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./hooks": {
      "types": "./dist/hooks/index.d.ts",
      "import": "./dist/hooks/index.js",
      "require": "./dist/hooks/index.cjs"
    },
    "./devtools": {
      "types": "./dist/devtools/index.d.ts",
      "import": "./dist/devtools/index.js",
      "require": "./dist/devtools/index.cjs"
    }
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "emittery": "^1.0.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitest/coverage-v8": "^1.2.0",
    "jsdom": "^24.0.0",
    "msw": "^2.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run lint && npm run test && npm run build"
  }
}
